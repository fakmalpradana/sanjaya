# SANJAYA WebGIS — Environment Variables
# Copy to .env and fill in values before running docker compose

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=sanjayapassword

# ── MinIO Object Store (S3-compatible) ────────────────────────────────────────
MINIO_ROOT_USER=sanjaya
MINIO_ROOT_PASSWORD=sanjayaminio123

# ── API Security ──────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string-minimum-32-characters

# ── Application URLs ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_API_BASE=http://localhost:8000/api/v1

# ── GeoServer (only needed with --profile full) ───────────────────────────────
GEOSERVER_PASSWORD=sanjayageoserver
